---
// Capa de fondo: grid oscuro + esquinas técnicas + partículas pixeladas únicas.
// Se posiciona fixed detrás del contenido y no bloquea pointer events.
---

<div class="bg-layer" aria-hidden="true">
  <div class="bg-grid"></div>

  <svg class="bg-corners" preserveAspectRatio="none" viewBox="0 0 100 100">
    <polyline class="corner tl" points="0,18 0,0 18,0" />
    <polyline class="corner tr" points="82,0 100,0 100,18" />
    <polyline class="corner bl" points="0,82 0,100 18,100" />
    <polyline class="corner br" points="82,100 100,100 100,82" />
  </svg>

  <canvas class="bg-particles"></canvas>

  <div class="bg-vignette"></div>
</div>

<style>
  .bg-layer {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
    background: #0a0a0a;
  }

  .bg-grid {
    position: absolute;
    inset: 0;
    --cell: 16px;
    background-image:
      linear-gradient(
        to right,
        rgba(255, 255, 255, 0.04) 0 1px,
        transparent 1px 3px
      ),
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.04) 0 1px,
        transparent 1px 3px
      );
    background-size:
      var(--cell) var(--cell),
      var(--cell) var(--cell);
    background-position:
      0 0,
      1px 1px;
  }

  .bg-corners {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .corner {
    fill: none;
    stroke: rgba(255, 255, 255, 0.35);
    stroke-width: 0.25;
    vector-effect: non-scaling-stroke;
  }

  .bg-particles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    opacity: 0.55;
  }

  .bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 40%,
      rgba(0, 0, 0, 0.55) 100%
    );
  }
</style>

<script>
  // Serpientes pixeladas: cada "gusano" avanza celda por celda sobre el grid,
  // puede girar (no en 180°), y deja una estela que se desvanece con el tiempo.
  // El fondo se redibuja cada frame con un fade (motion blur barato) que apaga
  // la estela vieja y mantiene el efecto serpenteante.

  const PIXEL = 8; // tamaño lógico de cada celda
  const STEP_MS = 90; // ms entre celdas (más lento = más tranquilo)
  const COLS = 0;
  const ROWS = 0;
  const DIRS: Array<[number, number]> = [
    [1, 0],
    [-1, 0],
    [0, 1],
    [0, -1],
  ];

  type Snake = {
    body: Array<[number, number]>;
    dir: number;
    life: number;
    maxLife: number;
  };

  function hashSeed(str: string): number {
    let h = 2166136261 >>> 0;
    for (let i = 0; i < str.length; i++) {
      h ^= str.charCodeAt(i);
      h = Math.imul(h, 16777619);
    }
    return h >>> 0;
  }

  function mulberry32(seed: number) {
    return () => {
      seed = (seed + 0x6d2b79f5) | 0;
      let t = seed;
      t = Math.imul(t ^ (t >>> 15), t | 1);
      t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

  const canvas = document.querySelector<HTMLCanvasElement>(".bg-particles");
  if (canvas) {
    const ctx = canvas.getContext("2d");
    if (ctx) {
      const dpr = Math.max(1, Math.min(window.devicePixelRatio || 1, 2));
      const rand = mulberry32(hashSeed("commands-agent-v1"));

      let cols = COLS;
      let rows = ROWS;
      const snakes: Snake[] = [];
      let lastStep = 0;

      const init = () => {
        const w = window.innerWidth;
        const h = window.innerHeight;
        canvas.width = Math.floor((w / PIXEL) * dpr);
        canvas.height = Math.floor((h / PIXEL) * dpr);
        canvas.style.width = w + "px";
        canvas.style.height = h + "px";
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        cols = Math.ceil(w / PIXEL);
        rows = Math.ceil(h / PIXEL);

        ctx.fillStyle = "#0a0a0a";
        ctx.fillRect(0, 0, w, h);

        // Densidad: 1 serpiente cada ~6500 px² de pantalla.
        const target = Math.max(
          6,
          Math.min(28, Math.floor((w * h) / 6500))
        );
        snakes.length = 0;
        for (let i = 0; i < target; i++) {
          spawnSnake();
        }
      };

      const spawnSnake = () => {
        const len = 6 + Math.floor(rand() * 10); // 6..15 segmentos
        const start: [number, number] = [
          Math.floor(rand() * cols),
          Math.floor(rand() * rows),
        ];
        const body: Array<[number, number]> = [];
        for (let i = 0; i < len; i++) {
          body.push([start[0] - i, start[1]]);
        }
        const maxLife = 120 + Math.floor(rand() * 240);
        snakes.push({
          body,
          dir: Math.floor(rand() * 4),
          life: maxLife,
          maxLife,
        });
      };

      const tryTurn = (s: Snake) => {
        // 25% de probabilidad por paso de girar 90° (nunca 180°).
        if (rand() > 0.25) return;
        const cur = DIRS[s.dir];
        // Opciones: perpendiculares.
        const options: Array<[number, number]> = [];
        for (let i = 0; i < 4; i++) {
          if (DIRS[i][0] === -cur[0] && DIRS[i][1] === -cur[1]) continue;
          if (DIRS[i][0] === cur[0] && DIRS[i][1] === cur[1]) continue;
          options.push(DIRS[i]);
        }
        const choice = options[Math.floor(rand() * options.length)];
        s.dir = DIRS.indexOf(choice);
      };

      const step = (s: Snake) => {
        tryTurn(s);
        const [dx, dy] = DIRS[s.dir];
        const head = s.body[0];
        let nx = head[0] + dx;
        let ny = head[1] + dy;

        // Si choca con el borde o sale del grid, respawnea.
        if (nx < 0 || ny < 0 || nx >= cols || ny >= rows) {
          s.body[0] = [
            Math.floor(rand() * cols),
            Math.floor(rand() * rows),
          ];
          s.dir = Math.floor(rand() * 4);
          s.life = s.maxLife;
          for (let i = 1; i < s.body.length; i++) {
            s.body[i] = [s.body[0][0] - i, s.body[0][1]];
          }
          return;
        }

        s.body.unshift([nx, ny]);
        // Mantener longitud.
        if (s.body.length > 14) s.body.pop();

        s.life--;
        if (s.life <= 0) {
          // Respawn: nueva posición, dirección, longitud.
          s.body = [];
          const start: [number, number] = [
            Math.floor(rand() * cols),
            Math.floor(rand() * rows),
          ];
          const len = 6 + Math.floor(rand() * 10);
          for (let i = 0; i < len; i++) {
            s.body.push([start[0] - i, start[1]]);
          }
          s.dir = Math.floor(rand() * 4);
          s.life = s.maxLife;
        }
      };

      const drawSegment = (
        x: number,
        y: number,
        alpha: number,
        isHead: boolean
      ) => {
        if (alpha <= 0) return;
        ctx.fillStyle = isHead
          ? `rgba(255,255,255,${(alpha + 0.25).toFixed(3)})`
          : `rgba(255,255,255,${alpha.toFixed(3)})`;
        ctx.fillRect(x * PIXEL, y * PIXEL, PIXEL, PIXEL);
      };

      const frame = (ts: number) => {
        const w = window.innerWidth;
        const h = window.innerHeight;

        // Fade del frame anterior → estela que se desvanece.
        ctx.fillStyle = "rgba(10,10,10,0.18)";
        ctx.fillRect(0, 0, w, h);

        // Steppea las serpientes cada STEP_MS (no cada frame).
        if (ts - lastStep >= STEP_MS) {
          lastStep = ts;
          for (const s of snakes) {
            step(s);
          }
        }

        // Redibuja con la posición actual (cabeza/cola).
        for (const s of snakes) {
          for (let i = s.body.length - 1; i >= 0; i--) {
            const [x, y] = s.body[i];
            const t = 1 - i / s.body.length; // 0=cola, 1=cabeza
            const alpha = 0.05 + t * 0.45;
            drawSegment(x, y, alpha, i === 0);
          }
        }

        requestAnimationFrame(frame);
      };

      window.addEventListener("resize", init, { passive: true });
      init();
      requestAnimationFrame(frame);
    }
  }
</script>

{
  "name": "commands-agent-cli",
  "version": "0.0.1",
  "type": "module",
  "description": "CLI companion for commands.agent",
  "bin": {
    "commands-agent": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=node --outfile=dist/index.js",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepare": "bun run build"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "5"
  }
}
